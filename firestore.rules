rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Lead rules: Server-only writes (via firebase-admin)
    // If we wanted client-side reads (e.g. for a dashboard), we'd add them here.
    // For now, it's strictly backend persistence.
    match /leads/{tx_ref} {
      allow read: if false; // Only server can read (firebase-admin bypasses rules)
      allow write: if false; // Only server can write
    }
  }
}
